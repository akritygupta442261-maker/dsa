package Arrays;

public class duplicateApproach2 {
    public static void main(String[] args) {
        int arr[]= {5,1,3,4,2,4};
        boolean flag[] = new boolean[6];
        for(int i=0; i<arr.length;i++){
            int ele= arr[i];
            if(flag[ele] ==true){
                System.out.println(ele);
            }else{
                flag[ele]= true;
            }
        }
    }
}
