package Arrays;

public class reverseSome {
    public static void main(String[] args) {
        int []arr = {5,6,8,9,1,60};
        int n= arr.length-1;
        int i=0; int j= n;
        while(i<j){
            int temp= arr[i];
            arr[i]= arr[j];
            arr[j]= temp;
            i++;
            j--;


        }
        for( int ele : arr){
            System.out.print(ele+" ");
        }

    }
}
